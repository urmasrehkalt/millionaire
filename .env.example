# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required for AI question generation. Get one at https://platform.openai.com/api-keys.
# If left empty, the app falls back to static questions from
# backend/app/services/fallback_questions.json.
OPENAI_API_KEY=

# OpenAI model used for question generation.
# Defaults to gpt-4o-mini if unset (fast and cheap, good Estonian support).
OPENAI_MODEL=gpt-4o-mini

# Application environment: development | production
# In development, CORS is permissive and detailed error messages are returned.
ENVIRONMENT=development

# FastAPI server settings (optional)
HOST=127.0.0.1
PORT=8000
