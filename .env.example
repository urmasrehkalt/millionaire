# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Required for AI question generation. Get one (free tier) at
# https://aistudio.google.com/app/apikey.
# If left empty, the app falls back to static questions from
# backend/app/services/fallback_questions.json.
GEMINI_API_KEY=

# Gemini model used for question generation.
# Defaults to gemini-2.5-flash if unset (free tier, good Estonian support).
GEMINI_MODEL=gemini-2.5-flash

# Application environment: development | production
# In development, CORS is permissive and detailed error messages are returned.
ENVIRONMENT=development

# FastAPI server settings (optional)
HOST=127.0.0.1
PORT=8005
